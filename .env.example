VITE_DATA_MODE=demo
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Product analytics (PostHog) — OPTIONAL. Without it, all product events safely
# no-op and posthog-js is never loaded. Use ONLY the public PostHog project API
# key (starts with "phc_") — never a personal/secret API key. Product-interaction
# events (campaign support, votes, questions, search, etc.) are sent to PostHog
# only when this is set. Aggregate page/traffic analytics are handled separately
# by Vercel Web Analytics (see below), which needs no key.
VITE_POSTHOG_KEY=
# PostHog ingestion host (public). Override only for EU/self-hosted PostHog.
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Vercel Web Analytics needs NO application secret or env var. It is enabled
# manually in the Vercel project dashboard (Project → Analytics → Web Analytics)
# and begins reporting after a deployment and real page visits. It measures
# aggregate traffic only (page views, visitors, routes, referrers, devices) —
# custom product events are NOT sent to Vercel.
# Absolute origin used for auth magic-link redirects and canonical links.
# Local development: http://localhost:5173
# Vercel production MUST set: VITE_SITE_URL=https://open-floor.ca
# Must be a full absolute URL (scheme + host, no trailing slash) — never the
# literal string "VITE_SITE_URL". If unset/invalid, the app falls back to the
# runtime origin and logs an error in production.
VITE_SITE_URL=http://localhost:5173
# Public contact email shown on the Contact page and in legal documents.
# Defaults to an obvious placeholder if unset — set the real address before launch.
VITE_CONTACT_EMAIL=
# Optional: only enable after configuring a server-side verification endpoint.
VITE_TURNSTILE_SITE_KEY=

# --- Phase 2 (company-universe live sync) — NOT USED YET ---
# These are placeholders for the SEC/FMP provider integration, sync Edge
# Function, and admin dashboard described in docs/company-universe.md as
# future work. No code in this repository reads them today. Do not set them
# expecting any behavior to change — see docs/company-universe.md for status.
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_PROJECT_REF=
# SUPABASE_FUNCTION_URL=
# FMP_API_KEY=
# FMP_BASE_URL=https://financialmodelingprep.com/stable
# SEC_COMPANY_DIRECTORY_URL=https://www.sec.gov/files/company_tickers_exchange.json
# SEC_USER_AGENT="Open Floor admin@example.com"
# COMPANY_SYNC_SECRET=
# PUBLIC_DISPLAY_FMP_ENRICHMENT=false
